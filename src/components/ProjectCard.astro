---
export interface Props {
  title: string;
  description: string;
  tags: string[];
  link?: string;
  github?: string;
  slug: string;
}

const { title, description, tags, link, github, slug } = Astro.props;
---

<div class="bg-gray-900 rounded-xl border border-gray-800 hover:border-blue-500/40 transition-all duration-300 hover:shadow-lg hover:shadow-blue-500/5 overflow-hidden group">
  <div class="p-6 flex flex-col h-full">
    <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-blue-300 transition-colors">
      {title}
    </h3>
    <p class="text-gray-400 mb-4 text-sm leading-relaxed flex-1">
      {description}
    </p>
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag) => (
        <span class="text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20 px-2 py-0.5 rounded-full">
          {tag}
        </span>
      ))}
    </div>
    <div class="flex gap-4 text-sm">
      <a
        href={`/projects/${slug}`}
        class="text-blue-400 font-medium hover:text-blue-300 transition-colors"
      >
        View Details →
      </a>
      {link && (
        <a
          href={link}
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-500 hover:text-gray-300 transition-colors"
        >
          Live Demo
        </a>
      )}
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-500 hover:text-gray-300 transition-colors"
        >
          GitHub
        </a>
      )}
    </div>
  </div>
</div>
