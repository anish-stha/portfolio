---
const currentPath = Astro.url.pathname;
---

<header class="border-b border-gray-800/50 bg-gray-950/90 backdrop-blur-md sticky top-0 z-50">
  <nav class="max-w-5xl mx-auto px-6 py-4">
    <div class="flex justify-between items-center">
      <a href="/" class="text-xl font-semibold text-white tracking-tight">
        Anish Shrestha
      </a>

      <div class="flex space-x-8">
        <a
          href="/"
          class={`text-sm font-medium transition-colors ${
            currentPath === '/'
              ? 'text-blue-400'
              : 'text-gray-400 hover:text-white'
          }`}
        >
          Home
        </a>
        <a
          href="/projects"
          class={`text-sm font-medium transition-colors ${
            currentPath.startsWith('/projects')
              ? 'text-blue-400'
              : 'text-gray-400 hover:text-white'
          }`}
        >
          Projects
        </a>
        <a
          href="/experience"
          class={`text-sm font-medium transition-colors ${
            currentPath === '/experience'
              ? 'text-blue-400'
              : 'text-gray-400 hover:text-white'
          }`}
        >
          Experience
        </a>
        <a
          href="/resume"
          class={`text-sm font-medium transition-colors ${
            currentPath === '/resume'
              ? 'text-blue-400'
              : 'text-gray-400 hover:text-white'
          }`}
        >
          Resume
        </a>
      </div>
    </div>
  </nav>
</header>
