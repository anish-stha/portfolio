---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resume - Anish Shrestha" description="Download my resume PDF">
  <div class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">
          Resume
        </h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Download my latest resume to view my professional background, skills, and experience.
        </p>
      </div>

      <!-- Download Section -->
      <div class="text-center mb-16">
        <a 
          href="/resume.pdf"
          download="resume.pdf"
          class="bg-blue-600 text-white px-8 py-4 rounded-lg font-medium hover:bg-blue-700 transition-colors inline-flex items-center text-lg"
        >
          <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          Download Resume PDF
        </a>
      </div>

      <!-- Additional Navigation -->
      <div class="text-center p-8 bg-gray-50 rounded-lg">
        <h3 class="text-xl font-semibold text-gray-900 mb-4">
          Explore More
        </h3>
        <p class="text-gray-600 mb-6">
          Learn more about my journey and see the projects I've worked on.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/experience"
            class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:bg-gray-50 transition-colors"
          >
            View Experience
          </a>
          <a 
            href="/projects"
            class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:bg-gray-50 transition-colors"
          >
            See My Projects
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>