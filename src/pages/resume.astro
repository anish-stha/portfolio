---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resume — Anish Shrestha" description="Download my resume PDF">
  <div class="py-20 px-6">
    <div class="max-w-3xl mx-auto">

      <div class="text-center mb-14">
        <h1 class="text-4xl font-bold text-white mb-4">Resume</h1>
        <p class="text-gray-500 max-w-xl mx-auto text-sm">
          Download my latest resume to view my professional background, skills, and experience.
        </p>
      </div>

      <div class="text-center mb-14">
        <a
          href="/resume.pdf"
          download="resume.pdf"
          class="inline-flex items-center gap-3 bg-blue-600 text-white px-8 py-4 rounded-xl font-semibold hover:bg-blue-700 transition-all hover:-translate-y-0.5 hover:shadow-lg hover:shadow-blue-500/25 text-lg"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Download Resume PDF
        </a>
      </div>

      <div class="text-center p-8 bg-gray-900 rounded-2xl border border-gray-800">
        <h3 class="text-lg font-semibold text-white mb-3">Explore More</h3>
        <p class="text-gray-500 mb-6 text-sm">Learn more about my journey and see the projects I've worked on.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/experience"
            class="border border-gray-700 text-gray-300 px-6 py-2.5 rounded-lg font-medium hover:bg-gray-800 transition-colors text-sm"
          >
            View Experience
          </a>
          <a
            href="/projects"
            class="border border-gray-700 text-gray-300 px-6 py-2.5 rounded-lg font-medium hover:bg-gray-800 transition-colors text-sm"
          >
            See My Projects
          </a>
        </div>
      </div>

    </div>
  </div>
</Layout>
