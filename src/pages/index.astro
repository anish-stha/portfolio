---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const featuredProjects = await getCollection('projects', ({ data }) => {
  return data.featured === true;
});
---

<Layout title="Your Name - Developer">
  <!-- Hero Section -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="flex flex-col lg:flex-row items-center gap-12">
        <!-- Photo -->
        <div class="lg:w-1/3">
          <div class="w-64 h-64 mx-auto lg:mx-0 rounded-full overflow-hidden bg-gray-200">
            <img 
              src="/src/assets/images/profile.jpg" 
              alt="Your Name"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
            />
            <div class="w-full h-full flex items-center justify-center text-gray-500 hidden">
              <span class="text-4xl">👤</span>
            </div>
          </div>
        </div>
        
        <!-- Intro -->
        <div class="lg:w-2/3 text-center lg:text-left">
          <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
            Hi, I'm <span class="text-blue-600">Your Name</span>
          </h1>
          <p class="text-xl text-gray-600 mb-8 leading-relaxed">
            I'm a passionate developer who loves creating meaningful digital experiences. 
            I specialize in web development and enjoy turning complex problems into 
            simple, beautiful solutions.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a 
              href="/projects" 
              class="bg-blue-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-700 transition-colors"
            >
              View My Work
            </a>
            <a 
              href="/resume.pdf" 
              download="resume.pdf"
              target="_blank"
              class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:bg-gray-50 transition-colors"
            >
              Download Resume
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="py-16 px-6 bg-gray-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">
          Featured Projects
        </h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredProjects.map((project) => (
            <a 
              href={`/projects/${project.slug}`}
              class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow p-6 border border-gray-200"
            >
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                {project.data.title}
              </h3>
              <p class="text-gray-600 mb-4">
                {project.data.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {project.data.tags.map((tag) => (
                  <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          ))}
        </div>
        <div class="text-center mt-12">
          <a 
            href="/projects" 
            class="text-blue-600 font-medium hover:text-blue-700 transition-colors"
          >
            View All Projects →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Quick About -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">About Me</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8">
        When I'm not coding, you can find me exploring new technologies, 
        contributing to open source projects, or sharing knowledge with the developer community.
      </p>
      <a 
        href="/experience" 
        class="text-blue-600 font-medium hover:text-blue-700 transition-colors"
      >
        Learn More About My Journey →
      </a>
    </div>
  </section>
</Layout>