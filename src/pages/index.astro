          </svg>
        </a>
        <a href="https://linkedin.com/in/your-profile" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="mailto:your.email@example.com" class="social-icon" aria-label="Email">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </a>
      </div>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/projects" class="btn-primary">View My Work</a>
        <a href="/resume.pdf" download="resume.pdf" target="_blank" class="btn-secondary">Download Resume</a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-gray-600 animate-bounce" aria-hidden="true">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ══════════════════ FEATURED PROJECTS GALLERY ══════════════════ -->
  <section class="py-24 px-6 bg-gray-950">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="section-heading">Featured Projects</h2>
        <p class="text-gray-500 mt-4 text-sm uppercase tracking-widest">A selection of work I'm proud of</p>
      </div>

      <!-- Filter tabs -->
      <div class="filter-tabs" role="tablist" aria-label="Filter projects by category">
        <button class="filter-tab active" data-filter="all" role="tab" aria-selected="true">All</button>
        <button class="filter-tab" data-filter="Software Engineering" role="tab" aria-selected="false">Software Engineering</button>
        <button class="filter-tab" data-filter="Data Engineering" role="tab" aria-selected="false">Data Engineering</button>
        <button class="filter-tab" data-filter="HealthTech / Bioinformatics" role="tab" aria-selected="false">HealthTech / Bioinformatics</button>
      </div>

      {featuredProjects.length > 0 ? (
        <>
          <div class="proj-gallery" id="projGallery">
            {featuredProjects.map((project) => (
              <div class="proj-item" data-category={project.data.category ?? 'uncategorized'}>
                <a href={`/projects/${project.slug}`} class="block h-full group">
                  <div class="proj-card">
                    <div class="flex items-start justify-between mb-5">
                      <div class="proj-icon">
                        {project.data.category === 'Data Engineering' ? (
                          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                          </svg>
                        ) : project.data.category === 'HealthTech / Bioinformatics' ? (
                          <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                          </svg>
                        ) : (
                          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                          </svg>
                        )}
                      </div>
                      <div class="flex items-center gap-2">
                        {project.data.category && (
                          <span class="proj-category-badge" data-cat={project.data.category}>
                            {project.data.category}
                          </span>
                        )}
                        <svg class="w-4 h-4 text-gray-600 group-hover:text-blue-400 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                      </div>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-2 group-hover:text-blue-300 transition-colors">
                      {project.data.title}
                    </h3>
                    <p class="text-gray-400 text-sm leading-relaxed mb-5 flex-1">
                      {project.data.description}
                    </p>
                    <div class="flex flex-wrap gap-2 mt-auto">
                      {project.data.tags.map((tag) => (
                        <span class="proj-tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                </a>
              </div>
            ))}
          </div>
          <p class="gallery-empty hidden text-center text-gray-600 py-16" id="galleryEmpty">
            No featured projects in this category yet.
          </p>
        </>
      ) : (
        <div class="text-center py-20 border border-dashed border-gray-800 rounded-2xl">
          <p class="text-gray-600 text-lg mb-2">No featured projects yet</p>
          <p class="text-gray-700 text-sm">
            Set <code class="text-blue-500">featured: true</code> in a project's frontmatter to show it here.
          </p>
        </div>
      )}

      <div class="text-center mt-10">
        <a href="/projects" class="text-blue-400 hover:text-blue-300 text-sm font-medium transition-colors">
          View All Projects &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════ WHY ME ══════════════════ -->
  <section class="py-24 px-6 why-me-bg">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="section-heading">Why Me</h2>
        <p class="text-gray-500 mt-4 text-sm uppercase tracking-widest">What I bring to the table</p>
      </div>

      <div class="why-grid">

        <div class="why-card">
          <div class="why-icon" style="background: rgba(59,130,246,0.1); border-color: rgba(59,130,246,0.2);">
            <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="why-title">Regulated Industry Depth</h3>
          <p class="why-desc">
            Years operating inside healthcare and clinical data environments where accuracy isn't aspirational — it's a legal and ethical requirement. I understand HIPAA constraints, audit trails, and the consequences of bad data later in Revenue Cycle Management.
          </p>
        </div>

        <div class="why-card">
          <div class="why-icon" style="background: rgba(139,92,246,0.1); border-color: rgba(139,92,246,0.2);">
            <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
            </svg>
          </div>
          <h3 class="why-title">Full-Stack Data Engineering</h3>
          <p class="why-desc">
            From REST API design and ingestion pipelines to Spark transformations and warehouse modeling — I own the entire data path. No handoff gaps, no finger-pointing between teams, just end-to-end ownership.
          </p>
        </div>

        <div class="why-card">
          <div class="why-icon" style="background: rgba(6,182,212,0.1); border-color: rgba(6,182,212,0.2);">
            <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="why-title">Production-Grade, Not Prototype-Grade</h3>
          <p class="why-desc">
            I've shipped systems that run daily against real patient data and financial records. My code is written to be observed, debugged, and maintained by a team — not just to pass a demo.
          </p>
        </div>

        <div class="why-card">
          <div class="why-icon" style="background: rgba(34,197,94,0.1); border-color: rgba(34,197,94,0.2);">
            <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="why-title">Teaching Instinct</h3>
          <p class="why-desc">
            A background in teaching sharpened how I communicate complex systems — to engineers, to stakeholders, and in code. Good documentation and clear architecture decisions aren't afterthoughts for me. I have mentored 8 Engineers and 2 IT professionals in my career.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════ MY JOURNEY ══════════════════ -->
  <section class="py-24 px-6 journey-bg">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="section-heading">My Journey</h2>
        <p class="text-gray-500 mt-4 text-sm uppercase tracking-widest">Where I've been and what I've built</p>
      </div>

      <!-- Column headers -->
      <div class="journey-headers">
        <div class="jh-exp">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Experience
        </div>
        <div class="jh-edu">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0112 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
          </svg>
          Education
        </div>
      </div>

      <!-- Time-scaled center-line timeline -->
      <div class="center-timeline" style={`height: ${timelineHeight}px`}>

        <!-- Year tick marks on the center line -->
        {yearTicks.map(({ year, top }) => (
          <div class="year-tick-row" style={`top: ${top}px`} aria-hidden="true">
            <span class="year-num year-num-l">{year}</span>
            <span class="year-num year-num-r">{year}</span>
          </div>
        ))}

        <!-- Experience (Left, newest at top) -->
        <div class="exp-side">
          {chronoExp.length > 0 ? chronoExp.map((exp) => {
            const layout = expLayouts.get(exp.id)!;
            return (
              <div class="tl-item" style={`top: ${layout.top}px; height: ${layout.height}px`}>
                <div class="tl-dot exp-dot"></div>
                <div class="journey-card">
                  <div class="jc-date jc-date-right">
                    {!exp.data.endDate && <span class="badge-current">Current</span>}
                    {formatDate(exp.data.startDate)} &mdash; {exp.data.endDate ? formatDate(exp.data.endDate) : 'Present'}
                  </div>
                  <h4 class="jc-title">{exp.data.position}</h4>
                  <p class="jc-org">{exp.data.company}</p>
                  {exp.data.location && <p class="jc-meta">{exp.data.location}</p>}
                  <p class="jc-desc">{exp.data.description}</p>
                </div>
              </div>
            );
          }) : (
            <div class="tl-item" style="top: 0; height: 80px">
              <div class="tl-dot exp-dot"></div>
              <div class="journey-card placeholder-card">
                <p class="text-gray-600 text-sm italic">
                  Add experience in <code class="text-blue-400">src/content/experience/</code>
                </p>
              </div>
            </div>
          )}
        </div>

        <!-- Education (Right, newest at top) -->
        <div class="edu-side">
          {chronoEdu.length > 0 ? chronoEdu.map((edu) => {
            const layout = eduLayouts.get(edu.id)!;
            return (
              <div class="tl-item" style={`top: ${layout.top}px; height: ${layout.height}px`}>
                <div class="tl-dot edu-dot"></div>
                <div class="journey-card">
                  <div class="jc-date">
                    {formatDate(edu.data.startDate)} &mdash; {edu.data.endDate ? formatDate(edu.data.endDate) : 'Present'}
                  </div>
                  <h4 class="jc-title">{edu.data.degree}{edu.data.field ? ` in ${edu.data.field}` : ''}</h4>
                  <p class="jc-org" style="color: #a78bfa;">{edu.data.school}</p>
                  {edu.data.location && <p class="jc-meta">{edu.data.location}</p>}
                  {edu.data.gpa && <p class="jc-meta">GPA: {edu.data.gpa}</p>}
                  {edu.data.description && <p class="jc-desc">{edu.data.description}</p>}
                </div>
              </div>
            );
          }) : (
            <div class="tl-item" style="top: 0; height: 80px">
              <div class="tl-dot edu-dot"></div>
              <div class="journey-card placeholder-card">
                <p class="text-gray-600 text-sm italic">
                  Add education in <code class="text-blue-400">src/content/education/</code>
                </p>
              </div>
            </div>
          )}
        </div>

      </div>
    </div>
  </section>

</Layout>

