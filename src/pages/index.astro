<Layout title="Anish Shrestha — Portfolio">

  <!-- ══════════════════ HERO ══════════════════ -->
  <section class="hero">
    <!-- Aurora background blobs -->
    <div class="aurora" aria-hidden="true">
      <div class="blob b1"></div>
      <div class="blob b2"></div>
      <div class="blob b3"></div>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 text-center max-w-3xl mx-auto px-6">

      <!-- Profile photo with spinning gradient ring -->
      <div class="flex justify-center mb-8">
        <div class="spin-ring">
          <div class="spin-counter">
            <Image
              src={profileImage}
              alt="Anish Shrestha"
              class="w-full h-full object-cover"
              width={200}
              height={200}
              format="webp"
              quality={90}
            />
          </div>
        </div>
      </div>

      <!-- Name & title -->
      <h1 class="text-5xl lg:text-7xl font-bold text-white mb-3 tracking-tight leading-tight">
        Anish Shrestha
      </h1>
      <p class="text-xl lg:text-2xl font-medium text-blue-400 mb-8">
       Sr. Engineer at the intersection of Healthcare, Data Insfrastructure, and Software Development&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-gray-300"></span>
      </p>

      <!-- Bio placeholder -->
      <p class="text-gray-500 text-base lg:text-lg max-w-xl mx-auto mb-10 leading-relaxed border border-dashed border-gray-700 rounded-lg px-6 py-4">
        Software Engineer by training, Sr. Data Engineer by trade. I build API-driven systems and Spark-optimized pipelines for industries where data integrity is a matter of life, death, or bottom-line stability.
      </p>
      <!-- Social icons -->
      <div class="flex gap-3 justify-center mb-10">
        <a href="https://discord.com/users/your-discord-id" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Discord">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419-.0189 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1568 2.4189Z"/>
