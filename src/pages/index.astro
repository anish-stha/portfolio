---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import profileImage from '../assets/images/profile.jpg';

const featuredProjects = await getCollection('projects', ({ data }) => {
  return data.featured === true;
});

const experiences = await getCollection('experience');
const sortedExperiences = experiences.sort((a, b) =>
  new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime()
);

const education = await getCollection('education');
const sortedEducation = education.sort((a, b) =>
  new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

// ── Time-scaled journey timeline ──
const PX_PER_YEAR = 200;
const MS_PER_YEAR = 365.25 * 24 * 60 * 60 * 1000;
const MIN_CARD_HEIGHT = 80;

const now = new Date();

const allDates: Date[] = [];
sortedExperiences.forEach(e => {
  allDates.push(e.data.startDate);
  allDates.push(e.data.endDate ?? now);
});
sortedEducation.forEach(e => {
  allDates.push(e.data.startDate);
  allDates.push(e.data.endDate ?? now);
});

const fallbackMin = new Date(now.getFullYear() - 4, 0, 1);
const minTime = allDates.length > 0 ? Math.min(...allDates.map(d => d.getTime())) : fallbackMin.getTime();
const maxTime = allDates.length > 0 ? Math.max(...allDates.map(d => d.getTime())) : now.getTime();

// Most recent at top: high time → small top value
function dateToTop(date: Date): number {
  return ((maxTime - date.getTime()) / MS_PER_YEAR) * PX_PER_YEAR;
}

// Already sorted newest-first
const chronoExp = [...sortedExperiences];
const chronoEdu = [...sortedEducation];

// Card layout: top anchored at endDate position, height spans the full duration
function computeCardLayouts(entries: typeof chronoExp): Map<string, { top: number; height: number }> {
  const map = new Map<string, { top: number; height: number }>();
  for (const e of entries) {
    const endDate = e.data.endDate ?? now;
    const top = Math.round(dateToTop(endDate));
    const rawHeight = Math.round(dateToTop(e.data.startDate) - top);
    const height = Math.max(rawHeight, MIN_CARD_HEIGHT);
    map.set(e.id, { top, height });
  }
  return map;
}

const expLayouts = computeCardLayouts(chronoExp);
const eduLayouts = computeCardLayouts(chronoEdu);

// Timeline height: natural span + ensure all cards fit
const naturalHeight = Math.round(((maxTime - minTime) / MS_PER_YEAR) * PX_PER_YEAR);
let maxBottom = naturalHeight;
for (const [, l] of expLayouts) maxBottom = Math.max(maxBottom, l.top + l.height);
for (const [, l] of eduLayouts) maxBottom = Math.max(maxBottom, l.top + l.height);
const timelineHeight = maxBottom + 100;

// Year tick marks (most recent near top)
const startYear = new Date(minTime).getFullYear();
const endYear   = new Date(maxTime).getFullYear();
const yearTicks = Array.from({ length: endYear - startYear + 1 }, (_, i) => {
  const year = startYear + i;
  return { year, top: Math.round(dateToTop(new Date(year, 0, 1))) };
});
